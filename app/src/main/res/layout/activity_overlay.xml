<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.cardview.widget.CardView
        android:id="@+id/paperCard"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="-500dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#F5F0E8"
            android:padding="28dp"
            android:gravity="center">

            <!-- Decorative line -->
            <View
                android:layout_width="60dp"
                android:layout_height="3dp"
                android:background="#A855F7"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/paperWord"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#1A1A2E"
                android:textSize="32sp"
                android:textStyle="bold"
                android:fontFamily="serif" />

            <TextView
                android:id="@+id/paperPron"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="#6B7280"
                android:textSize="13sp"
                android:fontFamily="serif" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#D1D5DB"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/paperMeaning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#374151"
                android:textSize="15sp"
                android:gravity="center"
                android:lineSpacingExtra="4dp" />

            <TextView
                android:id="@+id/paperMeaningNP"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="#7C3AED"
                android:textSize="14sp"
                android:textStyle="bold"
                android:gravity="center" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#D1D5DB"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/paperExample"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#6B7280"
                android:textSize="13sp"
                android:textStyle="italic"
                android:gravity="center"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:lineSpacingExtra="3dp" />

            <!-- Tap hint -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="tap to dismiss"
                android:textColor="#9CA3AF"
                android:textSize="11sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</FrameLayout>
