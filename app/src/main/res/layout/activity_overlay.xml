<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <androidx.cardview.widget.CardView
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:foreground="?android:attr/selectableItemBackground">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#E61A1A2E"
            android:padding="24dp"
            android:gravity="center">

            <TextView
                android:id="@+id/overlayCategory"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#A855F7"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.15" />

            <TextView
                android:id="@+id/overlayWord"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/overlayPron"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textColor="#9CA3AF"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/overlayMeaning"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="#D1D5DB"
                android:textSize="13sp"
                android:gravity="center" />

            <TextView
                android:id="@+id/overlayMeaningNP"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#C084FC"
                android:textSize="13sp"
                android:textStyle="bold"
                android:gravity="center" />

            <Button
                android:id="@+id/overlayDismiss"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="16dp"
                android:background="#33FFFFFF"
                android:text="Got it"
                android:textAllCaps="false"
                android:textColor="#9CA3AF"
                android:textSize="13sp" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</LinearLayout>
