<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:clickable="true"
    android:focusable="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp">

        <TextView
            android:id="@+id/overlayCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="@drawable/category_badge"
            android:paddingHorizontal="16dp"
            android:paddingVertical="4dp"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/overlayWord"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#e8e8ed"
            android:textSize="44sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/overlayPronunciation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="#6b7280"
            android:textSize="15sp"
            android:textStyle="italic" />

        <TextView
            android:id="@+id/overlayMeaning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:textColor="#9ca3af"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/overlayMeaningNP"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="#a5b4fc"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:text="Tap anywhere to dismiss"
            android:textColor="#4b5563"
            android:textSize="12sp" />

    </LinearLayout>
</FrameLayout>
