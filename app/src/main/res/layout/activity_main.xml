<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0f1a"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="40dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="WORDLOCK"
        android:textColor="#A855F7"
        android:textSize="14sp"
        android:textStyle="bold"
        android:letterSpacing="0.2" />

    <TextView
        android:id="@+id/wordText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#e8e8ed"
        android:textSize="36sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/meaningText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textColor="#9ca3af"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/meaningNPText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="#a5b4fc"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Tap the button below to enable"
        android:textColor="#9CA3AF"
        android:textSize="13sp" />

    <Button
        android:id="@+id/startOverlayBtn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/btn_primary"
        android:text="Enable WordLock"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="16sp" />

    <Button
        android:id="@+id/newWordBtn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/btn_outline"
        android:text="New Random Word"
        android:textAllCaps="false"
        android:textColor="#e8e8ed"
        android:textSize="16sp" />

</LinearLayout>
