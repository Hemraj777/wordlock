<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f0f1a"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="40dp">

    <TextView
        android:id="@+id/wordText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#e8e8ed"
        android:textSize="36sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/meaningText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:textColor="#9ca3af"
        android:textSize="16sp" />

    <TextView
        android:id="@+id/meaningNPText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#a5b4fc"
        android:textSize="15sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/startOverlayBtn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="48dp"
        android:background="@drawable/btn_primary"
        android:text="Enable Lock Screen Notification"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="16sp" />

    <Button
        android:id="@+id/newWordBtn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="12dp"
        android:background="@drawable/btn_outline"
        android:text="New Word"
        android:textAllCaps="false"
        android:textColor="#e8e8ed"
        android:textSize="16sp" />

</LinearLayout>
