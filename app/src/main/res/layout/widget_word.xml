<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center"
    android:background="@drawable/widget_background">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WORDLOCK"
        android:textColor="#A855F7"
        android:textSize="10sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/widgetCategory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#F9A8D4"
        android:textSize="9sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="6dp" />

    <TextView
        android:id="@+id/widgetWord"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#00E5FF"
        android:textSize="26sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:layout_gravity="center_horizontal" />

    <TextView
        android:id="@+id/widgetPron"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#94A3B8"
        android:textSize="11sp"
        android:fontFamily="sans-serif-light"
        android:layout_marginTop="2dp"
        android:layout_gravity="center_horizontal" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="───────────────"
        android:textColor="#55FFFFFF"
        android:textSize="10sp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:layout_gravity="center_horizontal" />

    <TextView
        android:id="@+id/widgetMeaning"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#E2E8F0"
        android:textSize="12sp"
        android:fontFamily="sans-serif"
        android:layout_gravity="center_horizontal" />

    <TextView
        android:id="@+id/widgetMeaningNP"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#E9D5FF"
        android:textSize="12sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        android:layout_gravity="center_horizontal" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="───────────────"
        android:textColor="#55FFFFFF"
        android:textSize="10sp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:layout_gravity="center_horizontal" />

    <TextView
        android:id="@+id/widgetExample"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#CBD5E1"
        android:textSize="11sp"
        android:textStyle="italic"
        android:fontFamily="serif"
        android:gravity="center"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:layout_gravity="center_horizontal" />

</LinearLayout>
